---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../config';
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header title="{SITE_TITLE}" />
		<div>
			<p class="big-type">Josiah Katz</p>
			<main>
				<h1>Josiah Katz, VP of Design & Media <span>York, PA</span></h1>
				<p>As the head of the creative teams at <a href="https://www.webstaurantstore.com" target="_blank">WebstaurantStore</a>, I'm responsible for leading a team of ~170 people who handle our user experiences, front-end development, graphic design, photography, 3D rendering, videography and social media.</p>
			</main>
		</div>
		<Footer />
	</body>
</html>
<style>
	/*-- Body - Custom Homepage Flexbox */
	@media (min-width:600px) {
		body {
			display: flex;
			align-items: center;
			justify-content: space-around;
		}
		main {
			width:80%;
			margin: 0 auto;
		}
	}
	/*-- Big Type */
	.big-type {
		font-size: 40vw;
		line-height: 28vw;
		letter-spacing: -0.5vw;	
		word-wrap: normal;
		margin: 0 -3vw 0;
	}
		@media (min-width:600px) {
			.big-type {
				font-size: 22vw;
				line-height: 18vw;
			}
		}
		p {
			font-size: 20px;
		}
</style>
